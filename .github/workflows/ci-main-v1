name: CI/CD Main - Auth Service
on:
  push:
    branches:
      - main
  workflow_dispatch:
jobs:
  docker_build:
    runs-on: self-hosted
    steps:
      - uses: actions/checkout@v6
      - run: env
      - name: Build image
        run: make docker-build image_tag=${GITHUB_SHA}

  test:
    runs-on: self-hosted
    needs: docker_build
    steps:
      - uses: actions/checkout@v6
      - name: Run Tests
        run:  echo "Running Test..."

  dev-deploy:
    runs-on: self-hosted
    needs: test
    environment: dev
    steps:
      - uses: actions/checkout@v6
      - uses: actions/checkout@v6
        with:
          repository: sh-devops-itrn-2/wmp-helm-v1
          path: helm
      - name: Helm Deploy
        run: make eks-deploy image_tag=${GITHUB_SHA}

  qa-deploy:
    runs-on: self-hosted
    needs: dev-deploy
    environment: qa
    steps:
      - uses: actions/checkout@v6
      - uses: actions/checkout@v6
        with:
          repository: sh-devops-itrn-2/wmp-helm-v1
          path: helm
      - name: Helm Deploy
        run: make eks-deploy image_tag=${GITHUB_SHA}
  uat-deploy:
    runs-on: self-hosted
    needs: qa-deploy
    environment: uat
    steps:
      - uses: actions/checkout@v6
      - uses: actions/checkout@v6
        with:
          repository: sh-devops-itrn-2/wmp-helm-v1
          path: helm
      - name: Helm Deploy
        run: make eks-deploy image_tag=${GITHUB_SHA}

  prod-deploy:
    runs-on: self-hosted
    needs: uat-deploy
    environment: prod
    steps:
      - uses: actions/checkout@v6
      - uses: actions/checkout@v6
        with:
          repository: sh-devops-itrn-2/wmp-helm-v1
          path: helm
      - name: Helm Deploy
        run: make eks-deploy image_tag=${GITHUB_SHA}